# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Jellyfin
JELLYFIN_URL=http://192.168.2.4:8096
JELLYFIN_API_KEY=your_jellyfin_api_key_here
JELLYFIN_USER_ID=your_jellyfin_user_id_here

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_LANGUAGE=en-US

# Homebridge
HOMEBRIDGE_URL=http://192.168.2.4:8581
HOMEBRIDGE_USERNAME=admin
HOMEBRIDGE_PASSWORD=admin

# Status badges
INDEXER_URL=http://192.168.2.4:9696
INDEXER_API_KEY=your_indexer_api_key_here
INDEXER_STATUS_PATH=/api/v1/health

# Direct client probes
QBITTORRENT_URL=http://192.168.2.4:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin
QBITTORRENT_STATUS_PATH=/api/v2/app/version
DOWNLOAD_ACTIVITY_MAX_ITEMS=50
EXTERNAL_HTTP_TIMEOUT_MS=10000

NZBGET_URL=http://192.168.2.4:6789
NZBGET_USERNAME=nzbget
NZBGET_PASSWORD=tegbzn6789
NZBGET_STATUS_PATH=/jsonrpc

# NAS / storage usage
NAS_USAGE_PATH=/mnt/nas
NAS_USAGE_LABEL=NAS

# NAS metrics over SNMP
NAS_METRICS_MODE=snmp
NAS_SNMP_HOST=192.168.2.10
NAS_SNMP_PORT=161
NAS_SNMP_VERSION=2c
NAS_SNMP_COMMUNITY=public
NAS_SNMP_TIMEOUT_MS=3500
NAS_SNMP_RETRIES=1

# Optional comma-separated include list (by interface name, eg: eth0,bond0)
NAS_NETWORK_INTERFACES=

# Backend-side cache to avoid polling the NAS on every request
NAS_METRICS_CACHE_TTL_MS=5000

# NAS metrics logging
NAS_METRICS_LOG_ENABLED=false
NAS_METRICS_LOG_VERBOSE=false

# Backend
PORT=3001
NODE_ENV=production

# Frontend
VITE_API_TIMEOUT_MS=20000
VITE_DASHBOARD_POLL_INTERVAL_MS=3000

