# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Jellyfin
JELLYFIN_URL=http://192.168.2.4:8096
JELLYFIN_API_KEY=your_jellyfin_api_key_here
JELLYFIN_USER_ID=your_jellyfin_user_id_here

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_LANGUAGE=en-US

# Homebridge
HOMEBRIDGE_URL=http://192.168.2.4:8581
HOMEBRIDGE_USERNAME=admin
HOMEBRIDGE_PASSWORD=admin

# Status badges
INDEXER_URL=http://192.168.2.4:9696
INDEXER_API_KEY=your_indexer_api_key_here
INDEXER_STATUS_PATH=/api/v1/health

# Direct client probes
QBITTORRENT_URL=http://192.168.2.4:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin
QBITTORRENT_STATUS_PATH=/api/v2/app/version

NZBGET_URL=http://192.168.2.4:6789
NZBGET_USERNAME=nzbget
NZBGET_PASSWORD=tegbzn6789
NZBGET_STATUS_PATH=/jsonrpc

# NAS / storage usage
NAS_USAGE_PATH=/mnt/nas
NAS_USAGE_LABEL=NAS

# Backend
PORT=3001
NODE_ENV=production
